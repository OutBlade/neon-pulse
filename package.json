{
  "name": "neon-pulse",
  "version": "0.4.0",
  "description": "A precision dash roguelike set in a neon-drenched void.",
  "main": "main.js",
  "author": "OutBlade",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "web": "npx --yes http-server src -p 5173 -o",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win --x64"
  },
  "dependencies": {
    "electron-updater": "^6.3.0"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "electron": "^32.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.outblade.neonpulse",
    "productName": "Neon Pulse",
    "copyright": "Copyright © 2026 OutBlade",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "package.json"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "OutBlade",
        "repo": "neon-pulse",
        "releaseType": "release"
      }
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "artifactName": "NeonPulseSetup-${version}.exe",
      "signingHashAlgorithms": null,
      "sign": null
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Neon Pulse"
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.games",
      "icon": "build/icon.icns"
    },
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Game",
      "icon": "build/icon.png"
    }
  }
}
